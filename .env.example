NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
GPTUNNEL_API_KEY=your_gptunnel_api_key
GPTUNNEL_BASE_URL=https://your-gptunnel-host/v1
GPTUNNEL_MODEL=your_model_name

# Кнопка «Админка» в меню + быстрый доступ (только эти email)
# Полный доступ к /admin также через admin_users в Supabase
ADMIN_EMAILS=you@example.com

# Реактивация пользователей (cron + email)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
CRON_SECRET=your_random_cron_secret
# Публичный URL приложения (локально, production или Vercel)
# Production: https://finpilot.neshablon-web.ru
# Vercel: https://finpilot-green-kappa.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=FinPilot <noreply@yourdomain.com>
